# KTB FUND MANAGER - API Keys Configuration
# Copy to .env and add your keys

# ALPHA VANTAGE (Optional - yFinance works without key)
# Get free key: https://www.alphavantage.co/support/#api-key
# 25 calls/day free, upgrades available
ALPHA_VANTAGE_API_KEY=

# ALPACA PAPER TRADING (Optional - for live paper trading)
# Get free keys: https://alpaca.markets/
# Paper trading = test with fake money, no real capital needed
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# OPENROUTER (Optional - for LLM rate limit boost)
# Free models work without key; key = higher limits
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# MODEL DEFAULT
DEFAULT_MODEL=nemotron
