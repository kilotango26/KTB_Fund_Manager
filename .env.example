# KTB Fund Manager - Environment Variables
# Copy this file to .env and fill in your API keys

# For running LLMs hosted by OpenAI (GPT-4, GPT-4o, etc.)
# Get your key from https://platform.openai.com/
OPENAI_API_KEY=your-openai-api-key

# For running LLMs hosted by Anthropic (Claude 3.5, Claude 4, etc.)
# Get your key from https://anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key

# For getting financial data
# Get your Financial Datasets API key from https://financialdatasets.ai/
FINANCIAL_DATASETS_API_KEY=your-financial-datasets-api-key

# Optional: Alpha Vantage for market data
# Get your key from https://www.alphavantage.co/
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key
