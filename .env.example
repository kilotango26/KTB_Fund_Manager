# KTB Fund Manager - Environment Variables
# Copy this file to .env and add your OpenRouter API key (optional but recommended)

# OPENROUTER API KEY (Optional but recommended for higher rate limits)
# Free models work WITHOUT this key, but adding it gives you higher limits.
# Get your free key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# OPTIONAL: Legacy Provider API Keys
# These are only needed if you want to fall back to direct providers
# For OpenRouter-only mode, these can be left empty.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# DEFAULT MODEL CONFIGURATION
# Select from free OpenRouter models:
# - "nemotron" -> nvidia/nemotron-3-super-120b-a12b:free (RECOMMENDED for Finance)
# - "llama" -> meta-llama/llama-3.3-70b-instruct:free
# - "gpt_oss" -> openai/gpt-oss-120b:free
# - "qwen" -> qwen/qwen3-coder:free
# - "trinity" -> arcee-ai/trinity-large-preview:free
DEFAULT_MODEL=nemotron

# MODEL FOR AGENT ROLES (optional - defaults to DEFAULT_MODEL)
# INVESTMENT_AGENTS_MODEL=nemotron
# ANALYSIS_AGENTS_MODEL=llama
# MANAGEMENT_AGENTS_MODEL=trinity
